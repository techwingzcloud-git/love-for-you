{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        }
    ],
    "functions": {
        "api/**/*.js": {
            "memory": 256,
            "maxDuration": 10
        }
    }
}